# ===========================================
# Email-to-Sheets Agent Configuration
# ===========================================

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===========================================
# Google Sheets Configuration
# ===========================================
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Sheet1

# For local development: path to service account JSON
GOOGLE_SERVICE_ACCOUNT_PATH=service_account.json

# For Render deployment: paste entire JSON as string (set in dashboard)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ===========================================
# Gmail Configuration
# ===========================================
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Filter emails by label
GMAIL_LABEL_FILTER=INBOX

# How often to check for new emails (in minutes)
GMAIL_CHECK_INTERVAL_MINUTES=5

# Optional: Only process emails from specific sender
FILTER_FROM_EMAIL=

# Internal team emails - skip emails initiated by these addresses
# (comma-separated list)
INTERNAL_TEAM_EMAILS=faizan@onescreensolutions.com,fatir@onescreensolutions.com,abdullah@onescreensolutions.com,nasir@onescreensolutions.com,huzaifa@onescreensolutions.com,shoaib@onescreensolutions.com,qursam@onescreensolutions.com,zaman@onescreensolutions.com,engineering@onescreensolutions.com,ops@onescreensolutions.com

# ===========================================
# Google Chat Configuration
# ===========================================
# ID of the Google Chat space (room) to monitor.  You can find this by
# looking at the URL of your Chat room and copying the part after
# ``spaces/``.  Leave blank to disable the Chat pipeline.
CHAT_SPACE_ID=

# Name of the worksheet used for chat messages.  This sheet will be
# created if it doesn't already exist.  Defaults to ``Sheet2`` so it
# doesn't conflict with the email sheet.
CHAT_SHEET_NAME=Sheet2

# Comma-separated list of email addresses whose messages should be
# captured from the Chat space.  Messages from other senders will be
# ignored.  Adjust this list to match your operations team.
CHAT_USER_EMAILS=talha@onescreensolutions.com,sijjil@onescreensolutions.com,junaid@onescreensolutions.com,david@onescreensolutions.com,alis@onescreensolutions.com

# How often to check for new chat messages (in minutes).  Set to 0 to
# disable automatic polling via the scheduler.  When disabled you can
# still run ``python chat_main.py`` manually.
CHAT_CHECK_INTERVAL_MINUTES=5

# When ``true``, the chat agent will import all messages from
# ``2026-01-01`` on the first run.  After initial import, set to
# ``false`` to only fetch messages from the last 7 days.  You can
# override this behaviour by passing --start/--end to chat_main.py.
CHAT_INITIAL_IMPORT=false

# Path to the OAuth2 client secrets file used for Chat authentication.
# By default this is the same as ``GMAIL_CREDENTIALS_PATH``.  Change
# if you have a separate client for Chat.
CHAT_CREDENTIALS_PATH=credentials.json

# Location where the Chat OAuth token will be saved when running
# locally.  You can also provide a JSON string via ``CHAT_TOKEN_JSON``
# environment variable on Render.
CHAT_TOKEN_PATH=chat_token.json

# ===========================================
# Server Configuration (for Render)
# ===========================================
PORT=10000
