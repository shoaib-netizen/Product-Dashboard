# ===========================================
# Email-to-Sheets Agent Configuration
# ===========================================

# Groq API Key (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===========================================
# Google Sheets Configuration
# ===========================================
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Sheet1

# For local development: path to service account JSON
GOOGLE_SERVICE_ACCOUNT_PATH=service_account.json

# For Render deployment: paste entire JSON as string (set in dashboard)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ===========================================
# Gmail Configuration
# ===========================================
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Filter emails by label
GMAIL_LABEL_FILTER=INBOX

# How often to check for new emails (in minutes)
GMAIL_CHECK_INTERVAL_MINUTES=5

# Optional: Only process emails from specific sender
FILTER_FROM_EMAIL=

# ===========================================
# Server Configuration (for Render)
# ===========================================
PORT=10000
